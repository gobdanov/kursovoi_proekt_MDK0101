<UserControl x:Class="KAMA_PRO_CRUD_APP.items.item_storage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:KAMA_PRO_CRUD_APP.items"
             mc:Ignorable="d" 
             d:DesignHeight="70" d:DesignWidth="400">
    <Grid Background="Aqua">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Label Content="test1" x:Name="name" HorizontalAlignment="Left" Grid.Column="0" />
        <Label Content="test1" x:Name="count" HorizontalAlignment="Left" Grid.Column="1" />
        <Label Content="test1" HorizontalAlignment="Left" Grid.Column="2" />
    </Grid>
</UserControl>
