        </StackPanel>

        <Border Grid.Column="0" Margin="5,5,5,5" Grid.Row="1" CornerRadius="20" Background="#f0f0f0">
            <StackPanel>
                <Label Content="сделка:" FontWeight="Bold"/>
                <Label Content="х4 2513"/>
                <Label Content="х2 3015"/>
                <Label Content="х8 3515"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="0" Margin="5,5,5,5" Grid.Row="2" Background="#f0f0f0" CornerRadius="20">
            <StackPanel>
                <Label Content="сделка:" FontWeight="Bold"/>
                <Label Content="12,5 ч"/>
            </StackPanel>
        </Border>

        <Rectangle Grid.Column="0" Margin="5,5,5,5" Grid.Row="3" Fill="#f0f0f0" RadiusX="20" RadiusY="20">
        </Rectangle>

        <Rectangle Grid.Column="1" Margin="5,5,5,5" Grid.Row="1" Grid.RowSpan="3" Fill="#f0f0f0" RadiusX="20" RadiusY="20">
        </Rectangle>
    </Grid>
</Page>
