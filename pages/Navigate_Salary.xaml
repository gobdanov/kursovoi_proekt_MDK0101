<Page x:Class="KAMA_PRO_CRUD_APP.pages.Navigate_Salary"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:KAMA_PRO_CRUD_APP.pages"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="700"
      Title="Navigate_Salary">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/style/styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition  Width="213*"/>
            <ColumnDefinition Width="487*"/>
        </Grid.ColumnDefinitions>
        <!--фон-->
            <StackPanel Grid.ColumnSpan="1" Background="#f0f0f0"/>
        
        <!--иконка пользователя-->
        <Grid Grid.ColumnSpan="1" Margin="10,30,0,0">
            <Rectangle HorizontalAlignment="Left" Height="46" Fill="White" VerticalAlignment="Top" Width="193" RadiusX="9.733" RadiusY="9.733"/>
            <Image HorizontalAlignment="Left" Source="/imgs/moai.png" Height="28" Margin="0,8" VerticalAlignment="Top" Width="28"/>
            <Label Content="вадим богданов" FontSize="16" HorizontalAlignment="Left" Margin="30,5,0,0" VerticalAlignment="Top" FontWeight="Bold" Width="153"/>
        </Grid>

        <StackPanel Grid.ColumnSpan="1" Width="213" Margin="0,100,0,0" HorizontalAlignment="Center" Height="254" VerticalAlignment="Top">
            
            <!--стили-->
            <StackPanel.Resources>
                <Style TargetType="Label">
                    <Setter Property="FontSize" Value="14"/>
                </Style>
                <Style TargetType="Grid">
                    <Setter Property="Margin" Value="0,0,0,20"/>
                </Style>
            </StackPanel.Resources>
            
            <!--меню-->
            <Grid Height="40">
                <Button>
                    <Grid>
                        <Image Source="/imgs/money-with-wings.png" Height="35" Width="35"/>
                    </Grid>
                </Button>
            </Grid>
            <Button Style="{StaticResource NavigateMenuButtonStyle}">
                <Grid Width="213" VerticalAlignment="Bottom">
                    <Label Content="зарплата" HorizontalAlignment="Left" Margin="45,0,0,0"/>
                    <Image Source="/imgs/money-with-wings.png" HorizontalAlignment="Left" Margin="10,0,0,0"/>
                </Grid>
            </Button>
            <Grid>
                <Label Content="сборка" Margin="50,0,0,0" />
                <Image Source="/imgs/hammer-and-wrench.png" Margin="10,0,173,0"/>
            </Grid>
            <Grid>
                <Label Content="планы" Margin="50,0,0,0" />
                <Image Source="/imgs/file-folder.png" Margin="10,0,173,0"/>
            </Grid>
            <Grid>
                <Label Content="склад" Margin="50,0,0,0" />
                <Image Source="/imgs/file-cabinet.png" Margin="10,0,173,0"/>
            </Grid>
            <Grid>
                <Label Content="сборщики" Margin="50,0,0,0" />
                <Grid Width="40" Height="40" Margin="10,0,173,0">
                    <Image Source="/imgs/mechanic-light-skin-tone.png" Width="25" Height="25" Margin="10,5,5,10"/>
                    <Image Source="/imgs/mechanic-medium-light-skin-tone.png" Width="25" Height="25" Margin="2,10,12,6"/>
                </Grid>
            </Grid>
        </StackPanel>


    </Grid>
</Page>
