<Page x:Class="KAMA_PRO_CRUD_APP.pages.Page_Storage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:KAMA_PRO_CRUD_APP.pages"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="487"
      Title="Page_Storage">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/style/styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="40"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="40"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="29*"/>
            <RowDefinition Height="451*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,135,144" Grid.RowSpan="3" Grid.ColumnSpan="3">
            <Label Content="склад" Margin="0,20,0,0" HorizontalAlignment="Left"  VerticalAlignment="Top" FontWeight="Bold" FontSize="14"/>

        </StackPanel>
        <Border BorderBrush="Black" BorderThickness="1"  Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,135,0" >
            <Grid  Background="AntiqueWhite">
                <Label Content="название"/>
            </Grid>
        </Border>

        <Border BorderBrush="Black" BorderThickness="1" Grid.Column="2" Grid.Row="1" >
            <Grid  Background="AntiqueWhite">
                <Label Content="количество"/>
            </Grid>
        </Border>

        <Border BorderBrush="Black" BorderThickness="1" Grid.Column="2" Grid.Row="1" Grid.ColumnSpan="2" Margin="135,0,0,0" >
            <Grid  Background="AntiqueWhite">
                <Label Content="действия"/>
            </Grid>
        </Border>

        <StackPanel x:Name="parent"  Grid.Column="1" Grid.Row="2" Grid.ColumnSpan="3"/>
        </Grid>
</Page>
