<Page x:Class="KAMA_PRO_CRUD_APP.pages.Authorizing"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:KAMA_PRO_CRUD_APP.pages"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="285"
      Title="autorizing">



    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/style/styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid Height="225" VerticalAlignment="Top" HorizontalAlignment="Right" Width="285">
            <Image HorizontalAlignment="Left" Opacity="0.3"  Source="/imgs/pricep_authorizing_page.jpg" Height="177" Margin="-10,50,0,0" VerticalAlignment="Top" Width="284"/>
            <Grid Margin="0,0,0,-50">
                <Label Content="кама" HorizontalAlignment="Left" Margin="58,88,0,0" VerticalAlignment="Top" FontSize="36" FontWeight="Bold"/>
                <Label Content="про" HorizontalAlignment="Left" Margin="149,88,0,0" VerticalAlignment="Top" FontSize="36" FontWeight="Bold" Foreground="Red"/>
            </Grid>
        </Grid>
        <Grid Margin="0,275,0,0" Height="275" VerticalAlignment="Top" HorizontalAlignment="Left" Width="285">
            <Label Content="логин" HorizontalAlignment="Left" Margin="32,7,0,0" VerticalAlignment="Top" FontSize="18"/>
            <TextBox HorizontalAlignment="Center" Margin="0,44,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="213" Height="29" FontSize="18" Style="{StaticResource MyTextBoxStyle}"/>
            <Label Content="пароль" HorizontalAlignment="Left" Margin="32,76,0,0" VerticalAlignment="Top" FontSize="18"/>
            <TextBox HorizontalAlignment="Center" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="213" Height="29" FontSize="18" Style="{StaticResource MyTextBoxStyle}" Margin="0,109,0,0"/>
            <Button Content="войти" HorizontalAlignment="Left" Click="SignIn"  Margin="92,154,0,0" VerticalAlignment="Top" Width="113" Height="32" FontSize="18" Style="{StaticResource MyButtonStyle}"/>
            <Label Margin="0,190,0,0" Foreground="#FFB2B2B2" HorizontalAlignment="Center" Width="273" Height="39" VerticalAlignment="Top" Cursor="" >
                <TextBlock TextAlignment="Center" Text="только администратор может зарегистрировать пользователя" TextWrapping="Wrap" FontSize="11" HorizontalAlignment="Left" Width="264"/>
            </Label>
        </Grid>
    </Grid>
</Page>

